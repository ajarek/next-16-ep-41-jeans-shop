rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.lower() == 'ajarek2101@gmail.com';
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function isCreatingOwnOrder() {
      return isSignedIn()
        && request.resource.data.uid == request.auth.uid;
    }

    // Produkty katalogu — publiczny odczyt, zapis tylko przez Admin/Console
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profil użytkownika — właściciel może czytać i pisać swoje dane
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.displayName is string;
      allow update: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // Zamówienia — użytkownik tworzy i czyta własne; admin czyta i aktualizuje wszystkie
    match /orders/{orderId} {
      // get + list: właściciel (uid) lub admin
      // list z where("uid" == request.auth.uid) jest dozwolone dzięki isOrderOwner()
      allow read: if isOrderOwner() || isAdmin();

      allow create: if isCreatingOwnOrder()
                    && request.resource.data.keys().hasAll([
                      'uid', 'items', 'totalAmount', 'discountAmount',
                      'shippingAddress', 'paymentMethod', 'createdAt',
                      'status', 'trackingNumber'
                    ])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.totalAmount is number
                    && request.resource.data.totalAmount >= 0
                    && request.resource.data.discountAmount is number
                    && request.resource.data.status is string
                    && request.resource.data.trackingNumber is string
                    && request.resource.data.createdAt is string
                    && request.resource.data.shippingAddress is map
                    && request.resource.data.paymentMethod is string;

      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
