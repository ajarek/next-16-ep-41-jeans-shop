rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Produkty katalogu — publiczny odczyt, zapis tylko przez Admin/Console
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Profil użytkownika — właściciel może czytać i pisać swoje dane
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.displayName is string;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // Zamówienia — użytkownik tworzy i czyta tylko własne
    match /orders/{orderId} {
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll([
                      'uid', 'items', 'totalAmount', 'discountAmount',
                      'shippingAddress', 'paymentMethod', 'createdAt',
                      'status', 'trackingNumber'
                    ])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.totalAmount is number
                    && request.resource.data.totalAmount >= 0;

      allow update, delete: if false;
    }
  }
}
